#: src/main.cpp
#, kde-kuit-format
msgctxt "@info"
msgid ""
"<para><application>Kleopatra</application> cannot be run as administrator "
"without breaking file permissions in the GnuPG data folder.</para><para>To "
"manage keys for other users please manage them as a normal user and copy the "
"<filename>%APPDATA%\\gnupg*</filename> directory with proper permissions.</"
"para>"
msgstr ""
"<para><application>Kleopatra</application> non può essere eseguito come "
"amministratore senza compromettere i permessi dei file nella cartella dati "
"di GnuPG.</para><para>Per gestire le chiavi di altri utenti, gestiscile come "
"utente normale e copia la cartella <filename>%APPDATA%\\gnupg*</filename> "
"con i permessi appropriati.</para>"

#: src/main.cpp
#, kde-kuit-format
msgctxt "@info"
msgid "<para>Are you sure that you want to continue at your own risk?</para>"
msgstr "<para>Sei sicuro di voler continuare a tuo rischio?</para>"

