#: src/commands/addadskcommand.cpp
#, kde-format
msgctxt "@info"
msgid ""
"<p>An error occurred while trying to add an ADSK to <b>%1</b>:</p><p>%2</p>"
msgstr ""
"<p>Si è verificato un errore durante il tentativo di aggiungere un'ADSK a "
"<b>%1</b>:</p><p>%2</p>"

