#, kde-format
msgctxt "@info"
msgid "ADSK added successfully."
msgstr "ADSK aggiunta correttamente."

#: src/commands/addadskcommand.cpp
#, kde-format
msgctxt "@info"
msgid ""
"By adding an ADSK to your certificate, you allow the owner of the ADSK to "
"decrypt all new messages that are encrypted for your certificate. Do you "
"want to add the ADSK specified in the GnuPG configuration to your "
"certificate?"
msgstr ""
"Aggiungendo un'ADSK al tuo certificato, consenti al proprietario dell'ADSK "
"di decifrare tutti i nuovi messaggi cifrati per il tuo certificato. Vuoi "
"aggiungere l'ADSK specificata nella configurazione di GnuPG al tuo "
"certificato?"

#: src/commands/addadskcommand.cpp
#, kde-format
msgctxt "@title:dialog"
msgid "Add ADSK"
msgstr "Aggiungi ADSK"

