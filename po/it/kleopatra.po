#, kde-format
msgctxt "@title:window"
msgid "Grant Certification Power"
msgstr "Concedi il potere di certificazione"

#: src/commands/changeownertrustcommand.cpp
#, kde-format
msgctxt "@action:button"
msgid "Grant Power"
msgstr "Concedi il potere"

