#: src/main.cpp
#, kde-kuit-format
msgctxt "@info"
msgid ""
"<para><application>Kleopatra</application> cannot be run as administrator "
"without breaking file permissions in the GnuPG data folder.</para><para>To "
"manage keys for other users please manage them as a normal user and copy the "
"<filename>%APPDATA%\\gnupg*</filename> directory with proper permissions.</"
"para>"
msgstr ""
"<para><application>Kleopatra</application> nemôže byť spustená ako správca "
"bez narušenia oprávnení súborov v priečinku údajov GnuPG.</para><para>Ak "
"chcete spravovať kľúče pre iných používateľov, spravujte ich ako bežný "
"používateľ a skopírujte priečinok <filename>%APPDATA%\\gnupg*</filename> s "
"príslušnými oprávneniami.</para>"

#: src/main.cpp
#, kde-kuit-format
msgctxt "@info"
msgid "<para>Are you sure that you want to continue at your own risk?</para>"
msgstr "<para>Ste si istý, že chcete pokračovať na vlastné riziko?</para>"

#: src/main.cpp src/main.cpp
#, kde-format
msgctxt "@title"
msgid "Running as Administrator"
msgstr "Running as Administrator"

#: src/main.cpp
#, kde-kuit-format
msgctxt "@info"
msgid ""
"<para><application>Kleopatra</application> should not be run as "
"administrator.</para><para>If you still want to run the application as "
"administrator at your own risk then set the registry value <filename>%1</"
"filename> to <icode>%2</icode>.</para>"
msgstr ""
"<para><application>Kleopatra</application> by sa nemala spúšťať ako správca."
"</para><para>Ak napriek tomu chcete spustiť aplikáciu ako správca na vlastné "
"riziko, nastavte hodnotu registra <filename>%1</filename> na <icode>%2</"
"icode>.</para>"

#: src/main.cpp
#, kde-kuit-format
msgctxt "@info"
msgid ""
"<para>The version of the <application>GpgME</application> library you are "
"running against is older than the one that the <application>GpgME++</"
"application> library was built against.</para><para><application>Kleopatra</"
"application> will not function in this setting.</para><para>Please ask your "
"administrator for help in resolving this issue.</para>"
msgstr ""
"<para>Verzia knižnice <application>GpgME</application>, ktorú používate, je "
"staršia než tá, voči ktorej bola zostavená knižnica <application>GpgME++</"
"application>.</para><para><application>Kleopatra</application> nebude "
"fungovať v tomto nastavení.</para><para>Prosím, požiadajte vášho "
"administrátora o pomoc pri riešení tohto problému.</para>"

#: src/main.cpp
#, kde-format
msgctxt "@title"
msgid "GpgME Too Old"
msgstr "Príliš staré GpgME"

#: src/main.cpp
#, kde-format
msgid "GPG UI Server Error"
msgstr "Chyba GPG UI Servera"

#: src/main.cpp
#, kde-format
msgctxt ""
"This error message is only shown on Windows when the socket to communicate "
"with Windows Explorer could not be created. This often times means that the "
"whole installation is buggy. e.g. GnuPG is not installed at all."
msgid ""
"<qt>The Kleopatra Windows Explorer Module could not be initialized.<br/>The "
"error given was: <b>%1</b><br/>This likely means that there is a problem "
"with your installation. Try reinstalling or contact your Administrator for "
"support.<br/>You can try to continue to use Kleopatra but there might be "
"other problems.</qt>"
msgstr ""
"<qt>Modul Kleopatra pre Windows Explorer sa nepodarilo inicializovať.<br/"
">Uvedená chyba bola: <b>%1</b><br/>To pravdepodobne znamená, že je problém s "
"vašou inštaláciou. Skúste preinštalovanie alebo kontaktujte svojho správcu "
"pre podporu.<br/>Môžete sa pokúsiť naďalej používať Kleopatra, ale môžu sa "
"vyskytnúť aj iné problémy.</qt>"

