msgstr "%1 Karta OpenPGP v%2"

#: src/view/smartcardwidget.cpp
#, kde-format
msgctxt "%1 is a smartcard manufacturer"
msgid "%1 PKCS#15 card"
msgstr "%1 karta PKCS#15"

#: src/view/smartcardwidget.cpp
#, kde-format
msgctxt "%1 version number"
msgid "PIV v%1 card"
msgstr "Karta PIV v%1"

#: src/view/smartcardwidget.cpp
#, kde-format
