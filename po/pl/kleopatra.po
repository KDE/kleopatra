msgid "Enter the new public key URL:"
msgstr "Wpisz nowy adresu URL publicznego klucza:"

#: src/view/smartcardswidget.cpp
#, kde-format
msgctxt "@info"
msgid "The URL is too long."
msgstr "Adres URL jest zbyt długi."

#: src/view/smartcardswidget.cpp src/view/smartcardswidget.cpp
#, kde-format
msgctxt "@info"
msgid "URL change failed: %1"
msgstr "Nie udała się zmiana adresu: %1"

#: src/view/smartcardwidget.cpp
#, kde-format
msgctxt "1 is a Version number"
