#: src/view/welcomewidget.cpp
#, kde-format
msgctxt "%1 is version"
msgid "Welcome to Kleopatra %1"
msgstr "Dobrodošli v Kleopatri %1"

#: src/view/welcomewidget.cpp
#, kde-format
msgid ""
"Kleopatra is a front-end for the crypto software <a href=\"https://"
"gnupg.org\">GnuPG</a>."
msgstr ""
"Kleopatra je začelje kripto programske opreme <a href = \"https://"
"gnupg.org\"> GnuPG</a>."

#: src/view/welcomewidget.cpp
#, kde-format
msgid ""
"For most actions you need either a public key (certificate) or your own "
"secret key."
msgstr ""
"Za večino dejanj potrebujete javni ključ (potrdilo) ali vaš lastni tajni "
"ključ."

#: src/view/welcomewidget.cpp
#, kde-format
msgid "The secret key is needed to decrypt or sign."
msgstr "Tajni ključ je potreben za dešifriranje ali podpisovanje."

#: src/view/welcomewidget.cpp
#, kde-format
msgid ""
"The public key can be used by others to verify your identity or encrypt to "
"you."
msgstr ""
"Javni ključ lahko drugi uporabijo za verificiranje vaše identitete ali za "
"šifriranje za vas."

#: src/view/welcomewidget.cpp
#, kde-format
msgctxt ""
"More info about public key cryptography, please link to your local version "
"of Wikipedia"
msgid "https://en.wikipedia.org/wiki/Public-key_cryptography"
msgstr "https://en.wikipedia.org/wiki/Public-key_cryptography"

#: src/view/welcomewidget.cpp
#, kde-format
msgctxt "%1 is a link to a wiki article"
msgid "You can learn more about this on <a href=\"%1\">Wikipedia</a>."
msgstr "Več o tem se lahko naučite na <a href=\"%1\">Wikipediji</a>."

#: src/view/welcomewidget.cpp
#, kde-format
msgctxt "@info"
msgid ""
"With Kleopatra you can encrypt using different methods. Please follow the "
"regulations for classified information of your organization."
msgstr ""
"S Kleopatro lahko šifrirate z različnimi metodami. Upoštevajte predpise za "
"zaupne podatke vaše organizacije."

#: src/view/welcomewidget.cpp
#, kde-format
msgctxt "@info"
msgid ""
"For password based encryption see this <a "
"href=\"action:help_doc_symenc\">guide</a>."
msgstr ""
"Za šifriranje na podlagi gesla glejte ta <a "
"href=\"action:help_doc_symenc\">vodnik</a>."

#: src/view/welcomewidget.cpp
#, kde-format
msgctxt "@info"
msgid ""
"For public key encryption you generally have to create your own key pair."
msgstr ""
"Za šifriranje z javnim ključem morate na splošno ustvariti svoj par ključev."

#: src/view/welcomewidget.cpp
#, kde-format
msgctxt "@info"
msgid ""
"You can find step-by-step instructions for public key encryption in this <a "
"href=\"action:help_doc_quickguide\">guide</a>."
msgstr ""
"Navodila korak po korak za šifriranje z javnim ključem najdete v tem <a "
"href=\"action:help_doc_quickguide\">vodniku</a>."

#: src/view/welcomewidget.cpp
#, kde-format
msgid "New Key Pair..."
msgstr "Novi par ključev…"

#: src/view/welcomewidget.cpp
#, kde-kuit-format
msgctxt "@info"
msgid ""
"Create a new OpenPGP key pair.<nl/>To create an S/MIME certificate request "
"use <interface>New S/MIME Certification Request</interface> from the "
"<interface>File</interface> menu instead."
msgstr ""
"Ustvari nov par ključev OpenPGP.<nl/>Namesto tega za kreiranje zahtevka za "
"potrdilo S/MIME uporabite <interface>Novi zahtevek za potrjevanje S/MIME</"
"interface> iz menija <interface>Datoteka</interface>."

#: src/view/welcomewidget.cpp
#, kde-kuit-format
msgctxt "@info"
msgid ""
"Import certificate from a file.<nl/>To import from a public keyserver use "
"<interface>Lookup on Server</interface> instead."
msgstr ""
"Uvozi potrdilo iz datoteke.<nl/>Za uvoz iz javnega strežnika ključev namesto "
"tega uporabite <interface>\"Iskanje na strežniku\"</interface>."
