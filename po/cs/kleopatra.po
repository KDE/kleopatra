#: src/commands/exportopenpgpcertstoservercommand.cpp:125
#, kde-kuit-format
msgctxt "@info"
msgid ""
"<para>When OpenPGP certificates have been exported to a public directory "
"server, it is nearly impossible to remove them again.</para><para>Before "
"exporting your certificate to a public directory server, make sure that you "
"have created a revocation certificate so you can revoke the certificate if "
"it is compromised, lost, or you forgot the passphrase.</para><para>Are you "
"sure you want to continue?</para>"
msgstr ""
"<para>Jakmile jsou certifikáty OpenPGP exportovány na veřejný adresářový "
"server, je téměř nemožné je odtud znovu odstranit.</para><para>Než "
"certifikát exportujete na veřejný adresářový server, ujistěte se, že jste "
"vytvořili certifikát pro zrušení platnosti, abyste mohli certifikát zrušit v "
"případě jeho zneužití, ztráty nebo zapomenutí hesla.</para><para>Opravdu "
"chcete pokračovat?</para>"

