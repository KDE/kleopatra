#: src/dialogs/weboftrustwidget.cpp:105 src/view/smartcardactions.cpp:101
#, kde-format
msgctxt "@action"
msgid "Show Certificate Details"
msgstr "Zobrazit podrobnosti certifikátu"

#: src/dialogs/weboftrustwidget.cpp:110
#, kde-format
msgctxt "@action"
msgid "Add Certification"
msgstr "Přidat certifikaci"

#: src/dialogs/weboftrustwidget.cpp:116
#, kde-format
msgctxt "@action"
msgid "Revoke Certification"
msgstr "Odvolat certifikaci"

#: src/dialogs/weboftrustwidget.cpp:122
#, kde-format
msgctxt "@action:button"
msgid "Fetch Missing Keys"
msgstr "Načíst chybějící klíče"

#: src/dialogs/weboftrustwidget.cpp:123
#, kde-format
msgctxt "@info:tooltip"
msgid ""
"Look up and import all keys that were used to certify the user IDs of this "
"key"
msgstr ""
"Vyhledat a importovat všechny klíče, které byly použity k ověření ID "
"uživatelů tohoto klíče"

#: src/dialogs/weboftrustwidget.cpp:143
#, kde-format
msgctxt "label:checkbox"
msgid "Show only my own certifications"
msgstr "Zobrazit pouze moje vlastní certifikáty"

#: src/dialogs/weboftrustwidget.cpp:270
#, kde-format
msgid ""
"You cannot revoke this certification because it wasn't made with one of your "
"keys (or the required secret key is missing)."
msgstr ""
"Tuto certifikaci nelze zrušit, protože nebyla vytvořena pomocí některého z "
"vašich klíčů (nebo chybí požadovaný tajný klíč)."

#: src/dialogs/weboftrustwidget.cpp:273
#, kde-format
msgctxt "@info:tooltip"
msgid "Revocation of self-certifications is currently not possible."
msgstr "Odvolání vlastních certifikátů není v současné době možné."

#: src/dialogs/weboftrustwidget.cpp:277
#, kde-format
msgctxt "@info:tooltip"
msgid ""
"You cannot revoke this revocation certification. (But you can re-certify the "
"corresponding user ID.)"
msgstr ""
"Toto odvolání certifikace nelze zrušit. (Můžete však znovu certifikovat "
"příslušné ID uživatele.)"

#: src/dialogs/weboftrustwidget.cpp:280
#, kde-format
msgctxt "@info:tooltip"
msgid "You cannot revoke this expired certification."
msgstr "Tuto vypršenou certifikaci nelze zrušit."

#: src/dialogs/weboftrustwidget.cpp:283
#, kde-format
msgctxt "@info:tooltip"
msgid "You cannot revoke this invalid certification."
msgstr "Tuto neplatnou certifikaci nelze zrušit."

#: src/dialogs/weboftrustwidget.cpp:286
#, kde-format
msgctxt "@info:tooltip"
msgid ""
"You cannot revoke this certification because the required secret key is not "
"available."
msgstr ""
"Tuto certifikaci nelze zrušit, protože není k dispozici požadovaný tajný "
"klíč."

#: src/dialogs/weboftrustwidget.cpp:294
#, kde-format
msgid ""
"You cannot revoke any of the certifications of this user ID. Select any of "
"the certifications for details."
msgstr ""
"Certifikáty tohoto uživatele nelze odvolat. Pro zobrazení podrobností "
"vyberte některý z certifikátů."

#: src/dialogs/weboftrustwidget.cpp:430
#, kde-kuit-format
msgctxt "@info"
msgid ""
"<para>An error occurred while loading the certifications: <message>%1</"
"message></para>"
msgstr ""
"<para>Při načítání certifikátů došlo k chybě: <message>%1</message></para>"

#: src/dialogs/weboftrustwidget.cpp:433
#, kde-format
msgctxt "@title"
msgid "Certifications Loading Failed"
msgstr "Načtení certifikací selhalo"

#. i18n: ectx: label, entry (cnPlaceholder), group (CertificateCreationWizard)
#: src/kcfg/settings.kcfg:8
#, kde-format
msgid "Placeholder for CN"
msgstr "Zástupné místo pro CN"

#. i18n: ectx: whatsthis, entry (cnPlaceholder), group (CertificateCreationWizard)
#: src/kcfg/settings.kcfg:9
#, kde-format
msgid ""
"This text will be used as placeholder text for the common name (CN) field of "
"S/MIME certificates."
msgstr ""
"Tento text bude použit jako zástupný v poli \"Common Name\" (CN) S/MIME "
"certifikátů."

#. i18n: ectx: label, entry (prefillCN), group (CertificateCreationWizard)
#: src/kcfg/settings.kcfg:13
#, kde-format
msgid "Prefill CN automatically"
msgstr "Automaticky vyplnit CN"

#. i18n: ectx: whatsthis, entry (prefillCN), group (CertificateCreationWizard)
#: src/kcfg/settings.kcfg:15
#, kde-format
msgid ""
"If true, then the common name (CN) field of S/MIME certificates will be "
"prefilled with information gathered from the system,\n"
"         e.g., from the email settings of the desktop or, on Windows, from "
"the Active Directory."
msgstr ""
"Pokud je tato možnost zaškrtnuta, bude pole \"Common Name\" (CN) S/MIME "
"certifikátů automaticky vyplněno údaji získanými ze systému,\n"
"         například z nastavení e-mailu v počítači nebo, v systému Windows, "
"ze služby Active Directory."

#. i18n: ectx: label, entry (emailPlaceholder), group (CertificateCreationWizard)
#: src/kcfg/settings.kcfg:19
#, kde-format
msgid "Hint for EMAIL"
msgstr "Tip pro e-mail"

#. i18n: ectx: whatsthis, entry (emailPlaceholder), group (CertificateCreationWizard)
#: src/kcfg/settings.kcfg:20
#, kde-format
msgid ""
"This text will be shown above the email address field of OpenPGP "
"certificates and as placeholder in that field for S/MIME certificates."
msgstr ""
"Tento text se zobrazí nad polem pro zadání e-mailové adresy u OpenPGP "
"certifikátů a jako zástupný text v tomto poli u S/MIME certifikátů."

#. i18n: ectx: label, entry (prefillEmail), group (CertificateCreationWizard)
#: src/kcfg/settings.kcfg:24
#, kde-format
msgid "Prefill EMAIL automatically"
msgstr "Automaticky vyplnit e-mail"

#. i18n: ectx: whatsthis, entry (prefillEmail), group (CertificateCreationWizard)
#: src/kcfg/settings.kcfg:26
#, kde-format
msgid ""
"If true, then the email address field of OpenPGP and S/MIME certificates "
"will be prefilled with information gathered from the system,\n"
"         e.g., from the email settings of the desktop or, on Windows, from "
"the Active Directory."
msgstr ""
"Pokud je tato možnost zapnutá, bude pole pro e-mailovou adresu v "
"certifikátech OpenPGP a S/MIME automaticky vyplněno údaji získanými ze "
"systému,\n"
"         například z nastavení e-mailu v desktopovém prostředí nebo, v "
"systému Windows, ze služby Active Directory."

#. i18n: ectx: label, entry (email), group (CertificateCreationWizard)
#: src/kcfg/settings.kcfg:30
#, kde-format
msgid "Value of EMAIL"
msgstr "Hodnota e-mailu"

#. i18n: ectx: whatsthis, entry (email), group (CertificateCreationWizard)
#: src/kcfg/settings.kcfg:31
#, kde-format
msgid ""
"Prefilled value for the email address field of OpenPGP and S/MIME "
"certificates. This will override EMAIL_prefill. It is useful if no or "
"unsuitable system settings are found for EMAIL_prefill."
msgstr ""
"Předvyplněná hodnota pro pole e-mailové adresy u certifikátů OpenPGP a S/"
"MIME. Tato hodnota přepíše proměnnou EMAIL_prefill. Je to užitečné v "
"případě, že pro proměnnou EMAIL_prefill nejsou nalezena žádná nebo jsou "
"nalezena nevhodná systémová nastavení."

#. i18n: ectx: label, entry (namePlaceholder), group (CertificateCreationWizard)
#: src/kcfg/settings.kcfg:35
#, kde-format
msgid "Hint for NAME"
msgstr "Tip pro jméno"

#. i18n: ectx: whatsthis, entry (namePlaceholder), group (CertificateCreationWizard)
#: src/kcfg/settings.kcfg:36
#, kde-format
msgid "This text will be shown above the name field of OpenPGP certificates."
msgstr "Tento text se zobrazí nad polem pro jméno v certifikátech OpenPGP."

#. i18n: ectx: label, entry (prefillName), group (CertificateCreationWizard)
#: src/kcfg/settings.kcfg:40
#, kde-format
msgid "Prefill NAME automatically"
msgstr "Automaticky vyplnit jméno"

#. i18n: ectx: whatsthis, entry (prefillName), group (CertificateCreationWizard)
#: src/kcfg/settings.kcfg:42
#, kde-format
msgid ""
"If true, then the name field of OpenPGP certificates will be prefilled with "
"information gathered from the system,\n"
"         e.g., from the email settings of the desktop or, on Windows, from "
"the Active Directory."
msgstr ""
"Pokud je tato možnost zapnutá, bude pole jméno v certifikátech OpenPGP "
"automaticky vyplněno údaji získanými ze systému,\n"
"         např. z nastavení e-mailu v desktopovém prostředí nebo, v systému "
"Windows, ze služby Active Directory."

#. i18n: ectx: label, entry (name), group (CertificateCreationWizard)
#: src/kcfg/settings.kcfg:46
#, kde-format
msgid "Value of NAME"
msgstr "Hodnota jména"

#. i18n: ectx: whatsthis, entry (name), group (CertificateCreationWizard)
#: src/kcfg/settings.kcfg:47
#, kde-format
msgid ""
"Prefilled value for the name field of OpenPGP certificates. This will "
"override NAME_prefill. It is useful if no or an unsuitable system setting is "
"found for NAME_prefill."
msgstr ""
"Přednastavená hodnota pro jméno v certifikátech OpenPGP. Tato hodnota "
"přepíše proměnnou NAME_prefill. Je to užitečné v případě, že pro proměnnou "
"NAME_prefill není nalezeno žádné systémové nastavení nebo je nalezené "
"nastavení nevhodné."

#. i18n: ectx: label, entry, group (CertificateCreationWizard)
#: src/kcfg/settings.kcfg:51
#, kde-format
msgid "Default validity period"
msgstr "Výchozí doba platnosti"

#. i18n: ectx: tooltip, entry, group (CertificateCreationWizard)
#: src/kcfg/settings.kcfg:52
#, kde-format
msgid ""
"Specifies the default validity period of new or extended OpenPGP keys in "
"days."
msgstr ""
"Určuje výchozí dobu platnosti nových nebo prodloužených klíčů OpenPGP v "
"dnech."

#. i18n: ectx: whatsthis, entry, group (CertificateCreationWizard)
#: src/kcfg/settings.kcfg:53
#, kde-format
msgid ""
"This setting specifies how many days an OpenPGP key will be valid by default "
"at creation or change of validity, or, in other words, after how many days "
"the key will expire. Set this to 0 for unlimited validity. If this setting "
"is not set or is set to a negative value, then new or extended OpenPGP keys "
"will be valid for three years (possibly clamped to the allowed minimum or "
"maximum validity period) by default."
msgstr ""
"Toto nastavení určuje, kolik dní bude klíč OpenPGP ve výchozím nastavení "
"platný při vytvoření nebo změně platnosti, nebo jinými slovy, po kolika "
"dnech klíč vyprší. Pro neomezenou platnost nastavte hodnotu 0. Pokud toto "
"nastavení není zadáno nebo je nastaveno na zápornou hodnotu, budou nové nebo "
"prodloužené klíče OpenPGP ve výchozím nastavení platné po dobu tří let "
"(případně omezeno na povolenou minimální nebo maximální dobu platnosti)."

#. i18n: ectx: label, entry, group (CertificateCreationWizard)
#: src/kcfg/settings.kcfg:57
#, kde-format
msgid "Minimum validity period"
msgstr "Minimální doba platnosti"

#. i18n: ectx: tooltip, entry, group (CertificateCreationWizard)
#: src/kcfg/settings.kcfg:58
#, kde-format
msgid ""
"Specifies the minimum allowed validity period of new or extended OpenPGP "
"keys in days."
msgstr ""
"Určuje minimální povolenou dobu platnosti nových nebo prodloužených klíčů "
"OpenPGP v dnech."

#. i18n: ectx: whatsthis, entry, group (CertificateCreationWizard)
#: src/kcfg/settings.kcfg:59
#, kde-format
msgid ""
"This setting specifies the minimum number of days a user can choose for the "
"validity period of OpenPGP certificates. It applies at key creation and "
"change of validity."
msgstr ""
"Toto nastavení určuje minimální počet dní, který si uživatel může zvolit "
"jako dobu platnosti certifikátů OpenPGP. Platí při vytváření klíče a při "
"změně doby platnosti."

#. i18n: ectx: label, entry, group (CertificateCreationWizard)
#: src/kcfg/settings.kcfg:63
#, kde-format
msgid "Maximum validity period"
msgstr "Maximální doba platnosti"

#. i18n: ectx: tooltip, entry, group (CertificateCreationWizard)
#: src/kcfg/settings.kcfg:64
#, kde-format
msgid ""
"Specifies the maximum allowed validity period of new or extended OpenPGP "
"keys in days."
msgstr ""
"Určuje maximální povolenou dobu platnosti nových nebo prodloužených klíčů "
"OpenPGP v dnech."

#. i18n: ectx: whatsthis, entry, group (CertificateCreationWizard)
#: src/kcfg/settings.kcfg:65
#, kde-format
msgid ""
"This setting specifies the maximum number of days a user can choose for the "
"validity period of OpenPGP certificates. It applies at key creation and "
"change of validity. If this setting is not set or is set to a negative "
"value, then unlimited validity is allowed."
msgstr ""
"Toto nastavení určuje maximální počet dní, který si uživatel může zvolit "
"jako dobu platnosti certifikátů OpenPGP. Platí při vytváření klíčů a při "
"změně doby platnosti. Pokud toto nastavení není zadáno nebo je nastaveno na "
"zápornou hodnotu, je povolena neomezená platnost."

#. i18n: ectx: label, entry, group (CertificateCreationWizard)
#: src/kcfg/settings.kcfg:69
#, kde-format
msgid "Hide advanced settings"
msgstr "Skrýt pokročilá nastavení"

#. i18n: ectx: whatsthis, entry, group (CertificateCreationWizard)
#: src/kcfg/settings.kcfg:70
#, kde-format
msgid ""
"If true, hides the advanced settings button in the new certificate wizard."
msgstr ""
"Pokud je tato možnost zaškrtnuta, skryje se tlačítko pokročilých nastavení v "
"průvodci vytvořením nového certifikátu."

#. i18n: ectx: label, entry, group (Certification)
#: src/kcfg/settings.kcfg:76
#, kde-format
msgid "Default certification validity"
msgstr "Výchozí doba platnosti certifikátu"

#. i18n: ectx: tooltip, entry, group (Certification)
#: src/kcfg/settings.kcfg:77
#, kde-format
msgid "Specifies the default validity of certifications in days."
msgstr "Určuje výchozí dobu platnosti certifikátů v dnech."

#. i18n: ectx: whatsthis, entry, group (Certification)
#: src/kcfg/settings.kcfg:78
#, kde-format
msgid ""
"This setting specifies how many days a certification is valid by default, "
"or, in other words, after how many days a new certification will expire. Set "
"this to 0 for unlimited validity of certifications."
msgstr ""
"Toto nastavení určuje, kolik dní má certifikát ve výchozím nastavení "
"platnost, nebo jinými slovy, po kolika dnech vyprší platnost nového "
"certifikátu. Chcete-li nastavit neomezenou platnost certifikátů, zadejte "
"hodnotu 0."

#. i18n: ectx: label, entry (ChecksumDefinitionId), group (ChecksumOperations)
#: src/kcfg/settings.kcfg:84
#, kde-format
msgid "Checksum program to use when creating checksum files"
msgstr "Program, který se má použít při vytváření souborů s kontrolním součtem"

#. i18n: ectx: label, entry (ShowResultsAfterSigningClipboard), group (Clipboard)
#: src/kcfg/settings.kcfg:90
#, kde-format
msgid "Show results after signing"
msgstr "Zobrazit výsledky po podepsání"

#. i18n: ectx: whatsthis, entry (ShowResultsAfterSigningClipboard), group (Clipboard)
#: src/kcfg/settings.kcfg:91
#, kde-format
msgid ""
"If true, then the results are shown after successfully signing the clipboard."
msgstr ""
"Pokud je to možné, výsledky se zobrazí po úspěšném podepsání obsahu schránky."

#. i18n: ectx: label, entry (ShowResultsAfterEncryptingClipboard), group (Clipboard)
#: src/kcfg/settings.kcfg:95
#, kde-format
msgid "Show results after encryption"
msgstr "Zobrazit výsledky po zašifrování"

#. i18n: ectx: whatsthis, entry (ShowResultsAfterEncryptingClipboard), group (Clipboard)
#: src/kcfg/settings.kcfg:96
#, kde-format
msgid ""
"If true, then the results are shown after successfully encrypting the "
"clipboard."
msgstr ""
"Pokud je tato volba zapnuta, výsledky se zobrazí po úspěšném zašifrování "
"obsahu schránky."

#. i18n: ectx: label, entry (cmsEnabled), group (CMS)
#: src/kcfg/settings.kcfg:102
#, kde-format
msgid "Enable S/MIME"
msgstr "Povolit S/MIME"

#. i18n: ectx: tooltip, entry (cmsEnabled), group (CMS)
#: src/kcfg/settings.kcfg:103
#, kde-format
msgid "Enables support for S/MIME (CMS)."
msgstr "Zapnout podporu pro S/MIME (CMS)."

#. i18n: ectx: whatsthis, entry (cmsEnabled), group (CMS)
#: src/kcfg/settings.kcfg:104
#, kde-format
msgid ""
"If false, then Kleopatra's main UI will not offer any functionality related "
"to S/MIME (CMS)."
msgstr ""
"Pokud je tato volba vypnuta, hlavní uživatelské rozhraní Kleopatry nebude "
"nabízet žádné funkce související s S/MIME (CMS)."

#. i18n: ectx: label, entry (cmsCertificateCreationAllowed), group (CMS)
#: src/kcfg/settings.kcfg:108
#, kde-format
msgid "Allow S/MIME certificate creation"
msgstr "Povolit vytváření certifikátů S/MIME"

#. i18n: ectx: tooltip, entry (cmsCertificateCreationAllowed), group (CMS)
#: src/kcfg/settings.kcfg:109
#, kde-format
msgid "Allows the creation of S/MIME certificate signing requests."
msgstr "Umožní vytvořit žádosti o vydání certifikátu S/MIME."

#. i18n: ectx: whatsthis, entry (cmsCertificateCreationAllowed), group (CMS)
#: src/kcfg/settings.kcfg:110
#, kde-format
msgid ""
"If false, then Kleopatra will not offer the creation of S/MIME certificate "
"signing requests."
msgstr ""
"Pokud je tato volba vypnuta, Kleopatra nebude nabízet vytváření žádostí o "
"vydání certifikátu S/MIME."

#. i18n: ectx: label, entry, group (CMS)
#: src/kcfg/settings.kcfg:114
#, kde-format
msgid "Save generated CSR as PEM"
msgstr "Uložit vygenerovaný CSR jako PEM"

#. i18n: ectx: whatsthis, entry, group (CMS)
#: src/kcfg/settings.kcfg:115
#, kde-format
msgid ""
"If true then the generated S/MIME certificate signing request will be saved "
"using PEM format. Otherwise, it is saved in binary format (PKCS#10)."
msgstr ""
"Pokud je tato volba zapnuta, bude vygenerovaná žádost o vydání certifikátu S/"
"MIME uložena ve formátu PEM. V opačném případě bude uložena v binárním "
"formátu (PKCS#10)."

#. i18n: ectx: label, entry (ShowAppearanceConfiguration), group (ConfigurationDialog)
#: src/kcfg/settings.kcfg:121
#, kde-format
msgid "Show appearance configuration"
msgstr "Zobrazit nastavení vzhledu"

#. i18n: ectx: label, entry (ShowCryptoOperationsConfiguration), group (ConfigurationDialog)
#: src/kcfg/settings.kcfg:125
#, kde-format
msgid "Show crypto operations configuration"
msgstr "Zobrazit nastavení kryptografických operací"

#. i18n: ectx: label, entry (ShowDirectoryServicesConfiguration), group (ConfigurationDialog)
#: src/kcfg/settings.kcfg:129
#, kde-format
msgid "Show directory services configuration"
msgstr "Zobrazit nastavení adresářových služeb"

#. i18n: ectx: label, entry (ShowGnuPGSystemConfiguration), group (ConfigurationDialog)
#: src/kcfg/settings.kcfg:133
#, kde-format
msgid "Show GnuPG system configuration"
msgstr "Zobrazit systémové nastavení GnuPG"

#. i18n: ectx: label, entry (ShowSmartCardsConfiguration), group (ConfigurationDialog)
#: src/kcfg/settings.kcfg:137
#, kde-format
msgid "Show smart cards configuration"
msgstr "Zobrazit nastavení čipové karty"

#. i18n: ectx: label, entry (ShowSMimeValidationConfiguration), group (ConfigurationDialog)
#: src/kcfg/settings.kcfg:141
#, kde-format
msgid "Show S/MIME validation configuration"
msgstr "Zobrazit nastavení ověřování S/MIME"

#. i18n: ectx: tooltip, entry (AttributeOrder), group (DN)
#: src/kcfg/settings.kcfg:148
#, kde-format
msgid "Specifies the display order of the DN attributes of X.509 certificates."
msgstr "Určuje pořadí zobrazení atributů DN u certifikátů X.509."

#. i18n: ectx: label, entry (AllowPublicKeyUpload), group (Export)
#: src/kcfg/settings.kcfg:154
#, kde-format
msgid "Allow upload of public keys to keyservers"
msgstr "Povolit nahrávání veřejných klíčů na servery klíčů"

#. i18n: ectx: whatsthis, entry (AllowPublicKeyUpload), group (Export)
#: src/kcfg/settings.kcfg:155
#, kde-format
msgid ""
"If this option is disabled then Kleopatra only allows the upload of OpenPGP "
"keys for which the user has the secret key."
msgstr ""
"Pokud je tato volba vypnuta, Kleopatra povolí nahrávání pouze těch klíčů "
"OpenPGP, k nimž má uživatel tajný klíč."

#. i18n: ectx: label, entry (UsePGPFileExt), group (FileOperations)
#: src/kcfg/settings.kcfg:161
#, kde-format
msgid "Use pgp as the default extension for generated OpenPGP files"
msgstr "Nastavit pgp jako výchozí příponu pro generované soubory OpenPGP"

#. i18n: ectx: whatsthis, entry (UsePGPFileExt), group (FileOperations)
#: src/kcfg/settings.kcfg:162
#, kde-format
msgid ""
"Set this to make kleopatra default to pgp file extensions for OpenPGP files."
msgstr ""
"Nastavit tuto možnost, aby Kleopatra automaticky rozpoznávala soubory "
"OpenPGP podle přípon PGP."

#. i18n: ectx: label, entry (AutoExtractArchives), group (FileOperations)
#: src/kcfg/settings.kcfg:166
#, kde-format
msgid "Automatically extract archives after decryption."
msgstr "Po dešifrování archivy automaticky rozbalit."

#. i18n: ectx: whatsthis, entry (AutoExtractArchives), group (FileOperations)
#: src/kcfg/settings.kcfg:167
#, kde-format
msgid ""
"If this option is set, then Kleopatra automatically extracts file archives "
"after decryption."
msgstr ""
"Pokud je tato volba zapnuta, Kleopatra po dešifrování automaticky rozbalí "
"soubory archivů."

#. i18n: ectx: label, entry (ArchiveCommand), group (FileOperations)
#: src/kcfg/settings.kcfg:171
#, kde-format
msgid "Use this command to create file archives."
msgstr "Tento příkaz slouží k vytváření souboru archivů."

#. i18n: ectx: whatsthis, entry (ArchiveCommand), group (FileOperations)
#: src/kcfg/settings.kcfg:172
#, kde-format
msgid ""
"When encrypting multiple files or a folder Kleopatra creates an encrypted "
"archive with this command."
msgstr ""
"Při šifrování více souborů nebo složky vytvoří Kleopatra pomocí tohoto "
"příkazu šifrovaný archiv."

#. i18n: ectx: label, entry (AddASCIIArmor), group (FileOperations)
#: src/kcfg/settings.kcfg:176
#, kde-format
msgid "Create signed or encrypted files as text files."
msgstr "Vytvořit podepsané nebo zašifrované soubory jako textové soubory."

#. i18n: ectx: whatsthis, entry (AddASCIIArmor), group (FileOperations)
#: src/kcfg/settings.kcfg:177
#, kde-format
msgid ""
"Set this option to encode encrypted or signed files as base64 encoded text. "
"So that they can be opened with an editor or sent in a mail body. This will "
"increase file size by one third."
msgstr ""
"Nastavte tuto možnost tak, aby se šifrované nebo podepsané soubory kódovaly "
"jako text v kódování Base64. Díky tomu je bude možné otevřít v textovém "
"editoru nebo odeslat v těle e-mailu. Tím se velikost souboru zvětší o jednu "
"třetinu."

#. i18n: ectx: label, entry (DontUseTmpDir), group (FileOperations)
#: src/kcfg/settings.kcfg:181
#, kde-format
msgid "Create temporary decrypted files in the folder of the encrypted file."
msgstr "Vytvořit dočasně dešifrované soubory ve složce šifrovaného souboru."

#. i18n: ectx: whatsthis, entry (DontUseTmpDir), group (FileOperations)
#: src/kcfg/settings.kcfg:182
#, kde-format
msgid "Set this option to avoid using the users temporary directory."
msgstr ""
"Tuto možnost nastavte, pokud nechcete používat dočasný adresář uživatele."

#. i18n: ectx: label, entry (SymmetricEncryptionOnly), group (FileOperations)
#: src/kcfg/settings.kcfg:186
#, kde-format
msgid "Use symmetric encryption only."
msgstr "Použít pouze symetrické šifrování."

#. i18n: ectx: whatsthis, entry (SymmetricEncryptionOnly), group (FileOperations)
#: src/kcfg/settings.kcfg:187
#, kde-format
msgid "Set this option to disable public key encryption."
msgstr "Nastavte tuto možnost, chcete-li zakázat šifrování veřejným klíčem."

#. i18n: ectx: label, entry (PublicKeyEncryptionOnly), group (FileOperations)
#: src/kcfg/settings.kcfg:191
#, kde-format
msgid "Use public key encryption only."
msgstr "Použít pouze šifrování veřejným klíčem."

#. i18n: ectx: whatsthis, entry (PublicKeyEncryptionOnly), group (FileOperations)
#: src/kcfg/settings.kcfg:192
#, kde-format
msgid "Set this option to disable password-based encryption."
msgstr "Nastavte tuto možnost, chcete-li deaktivovat šifrování pomocí hesla."

#. i18n: ectx: label, entry (GroupsEnabled), group (Groups)
#: src/kcfg/settings.kcfg:198
#, kde-format
msgid "Enable Groups"
msgstr "Povolit skupiny"

#. i18n: ectx: tooltip, entry (GroupsEnabled), group (Groups)
#: src/kcfg/settings.kcfg:199
#, kde-format
msgid "Enable usage of groups of keys."
msgstr "Povolit používání skupin klíčů."

#. i18n: ectx: whatsthis, entry (GroupsEnabled), group (Groups)
#: src/kcfg/settings.kcfg:200
#, kde-format
msgid "Enable usage of groups of keys to create lists of recipients."
msgstr "Povolit použití skupin klíčů k vytváření seznamů příjemců."

#. i18n: ectx: label, entry (RetrieveSignerKeysAfterImport), group (Import)
#: src/kcfg/settings.kcfg:206
#, kde-format
msgid "Retrieve signer keys after import"
msgstr "Načíst po importu klíče podepisujících osob"

#. i18n: ectx: whatsthis, entry (RetrieveSignerKeysAfterImport), group (Import)
#: src/kcfg/settings.kcfg:209
#, kde-format
msgid ""
"If enabled, then Kleopatra will automatically try to retrieve the keys\n"
"         that were used to certify the user ids of newly imported OpenPGP "
"keys. This is\n"
"         useful in combination with trusted introducers."
msgstr ""
"Pokud je tato funkce zapnutá, Kleopatra se automaticky pokusí načíst "
"klíče,         které byly použity k ověření identit uživatelů nově "
"importovaných klíčů OpenPGP. To je         užitečné v kombinaci s "
"důvěryhodnými zprostředkovateli."

#. i18n: ectx: label, entry (QueryWKDsForAllUserIDs), group (Import)
#: src/kcfg/settings.kcfg:213
#, kde-format
msgid "Query certificate directories of providers for all user IDs"
msgstr "Prohledat adresáře certifikátů poskytovatelů pro všechna ID uživatelů"

#. i18n: ectx: whatsthis, entry (QueryWKDsForAllUserIDs), group (Import)
#: src/kcfg/settings.kcfg:216
#, kde-format
msgid ""
"By default, Kleopatra only queries the certificate directories of providers "
"(WKD)\n"
"         for user IDs that were originally retrieved from a WKD when you "
"update an OpenPGP certificate.\n"
"         If this option is enabled, then Kleopatra will query WKDs for all "
"user IDs."
msgstr ""
"Ve výchozím nastavení Kleopatra při aktualizaci certifikátu OpenPGP "
"prohledává adresáře certifikátů poskytovatelů (WKD) pouze\n"
"         pro ID uživatelů, která byla původně načtena z WKD.\n"
"         Pokud je tato možnost zapnutá, bude Kleopatra prohledávat WKD pro "
"všechna ID uživatelů."

#. i18n: ectx: label, entry (ShowExpiryNotifications), group (Notifications)
#: src/kcfg/settings.kcfg:222
#, kde-format
msgid "Notify about upcoming certificate expiration"
msgstr "Upozornit na blížící se vypršení platnosti certifikátu"

#. i18n: ectx: whatsthis, entry (ShowExpiryNotifications), group (Notifications)
#: src/kcfg/settings.kcfg:224
#, kde-format
msgid ""
"If enabled, then Kleopatra will show notifications in some place when using\n"
"        certificates that are about to expire soon."
msgstr ""
"Pokud je tato volba zapnuta, Kleopatra bude při používání\n"
"        certifikátů, jejichž platnost brzy vyprší, zobrazovat upozornění."

#. i18n: ectx: label, entry (BlockedUrlSchemes), group (Privacy)
#: src/kcfg/settings.kcfg:230
#, kde-format
msgid "URL schemes to block"
msgstr "Seznam URL adres k zablokování"

#. i18n: ectx: whatsthis, entry (BlockedUrlSchemes), group (Privacy)
#: src/kcfg/settings.kcfg:232
#, kde-format
msgid ""
"This is a list of URL schemes that shall be blocked by the application.\n"
"         This can be used to prevent the application from opening external "
"applications for certain URLs."
msgstr ""
"Toto je seznam URL adres, které má aplikace blokovat.\n"
"         Tuto funkci lze využít k tomu, aby aplikace u určitých URL adres "
"neotevírala externí aplikace."

#. i18n: ectx: label, entry (AlwaysSearchCardOnKeyserver), group (Smartcard)
#: src/kcfg/settings.kcfg:238
#, kde-format
msgid "Always search smartcard certificates on keyserver"
msgstr "Vždy vyhledávat certifikáty čipových karet na serveru klíčů"

#. i18n: ectx: tooltip, entry (AlwaysSearchCardOnKeyserver), group (Smartcard)
#: src/kcfg/settings.kcfg:239
#, kde-format
msgid ""
"Searches for the certificates belonging the smartcard keys on the configured "
"keyserver."
msgstr ""
"Vyhledá certifikáty přiřazené ke klíčům čipových karet na nastaveném serveru "
"klíčů."

#. i18n: ectx: whatsthis, entry (AlwaysSearchCardOnKeyserver), group (Smartcard)
#: src/kcfg/settings.kcfg:241
#, kde-format
msgid ""
"Searches on keyservers regardless of the protocol for the smartcards key, "
"regardless\n"
"        of the keyserver protocol. Default behavior is to only do this for "
"LDAP keyservers."
msgstr ""
"Vyhledávání klíče čipové karty na serverech klíčů bez ohledu na protokol "
"klíče čipové karty, bez ohledu\n"
"        na protokol serveru klíčů. Výchozí nastavení je provádět toto "
"vyhledávání pouze u serverů klíčů LDAP."

#. i18n: ectx: label, entry (autoLoadP15Certs), group (Smartcard)
#: src/kcfg/settings.kcfg:245
#, kde-format
msgid "Try to load S/MIME certificates from PKCS#15 smartcards"
msgstr "Zkusit načíst certifikáty S/MIME z čipových karet formátu PKCS#15"

#. i18n: ectx: tooltip, entry (autoLoadP15Certs), group (Smartcard)
#: src/kcfg/settings.kcfg:246
#, kde-format
msgid "Automatically load S/MIME certificates from PKCS#15 (CardOS) smartcards"
msgstr ""
"Automatické načtení certifikátů S/MIME z čipových karet PKCS#15 (CardOS)"

#. i18n: ectx: whatsthis, entry (autoLoadP15Certs), group (Smartcard)
#: src/kcfg/settings.kcfg:247
#, kde-format
msgid ""
"If true, then Kleopatra will call gpgsm --learn if a PKCS#15 Smartcard is "
"inserted with unknown certificates. This can take a while and blocks the "
"smartcard while the command is running."
msgstr ""
"Pokud je tato volba zapnutá, spustí Kleopatra příkaz gpgsm --learn v "
"případě, že je vložena čipová karta PKCS#15 s neznámými certifikáty. Tento "
"proces může chvíli trvat a během jeho provádění je čipová karta zablokována."

#. i18n: ectx: label, entry (RefreshInterval), group (SMime Validation)
#: src/kcfg/settings.kcfg:253
#, kde-format
msgid "Certificate refresh interval (in hours). Zero (0) disables."
msgstr ""
"Interval obnovení certifikátu (v hodinách). Hodnota nula (0) funkci "
"deaktivuje."

#. i18n: ectx: label, entry (ProfilesDisabled), group (General)
#: src/kcfg/settings.kcfg:261
#, kde-format
msgid "Disable profile settings"
msgstr "Vypnout nastavení profilu"

#. i18n: ectx: label, entry (AllowCustomDebugCommands), group (General)
#: src/kcfg/settings.kcfg:265
#, kde-format
msgid "Allow custom debug commands"
msgstr "Povolit vlastní ladicí příkazy"

#. i18n: ectx: label, entry (ShowResultsAfterSignEncrypt), group (General)
#: src/kcfg/settings.kcfg:269
#, kde-format
msgid "Show results after signing and encrypting files"
msgstr "Zobrazit výsledky po podepsání a zašifrování souborů"

#. i18n: ectx: label, entry (RestoreSignEncryptValues), group (General)
#: src/kcfg/settings.kcfg:273
#, kde-format
msgid "Use last-used values for the sign/encrypt configuration"
msgstr "Použít naposledy použité hodnoty pro nastavení šifrování/podepisování"

#. i18n: ectx: label, entry (ShowValidity), group (Tooltip)
#: src/kcfg/settings.kcfg:279
#, kde-format
msgid "Show certificate validity"
msgstr "Zobrazit platnosti certifikátu"

#. i18n: ectx: whatsthis, entry (ShowValidity), group (Tooltip)
#: src/kcfg/settings.kcfg:280
#, kde-format
msgid ""
"Show validity information for certificates in tooltip, such as whether the "
"certificate is expired or revoked."
msgstr ""
"Zobrazit informace o platnosti certifikátů v popisku, například zda "
"certifikát vypršel nebo byl odvolán."

#. i18n: ectx: label, entry (ShowOwnerInformation), group (Tooltip)
#: src/kcfg/settings.kcfg:284
#, kde-format
msgid "Show certificate owner information"
msgstr "Zobrazit údaje o vlastníkovi certifikátu"

#. i18n: ectx: whatsthis, entry (ShowOwnerInformation), group (Tooltip)
#: src/kcfg/settings.kcfg:285
#, kde-format
msgid ""
"Show owner information for certificates in tooltip, such as User IDs, "
"subject and issuers."
msgstr ""
"Zobrazit informace o vlastníkovi certifikátů v popisku, jako jsou ID "
"uživatelů, předmět a vydavatelé."

#. i18n: ectx: label, entry (ShowCertificateDetails), group (Tooltip)
#: src/kcfg/settings.kcfg:289
#, kde-format
msgid "Show certificate details"
msgstr "Zobrazit podrobnosti certifikátu"

#. i18n: ectx: whatsthis, entry (ShowCertificateDetails), group (Tooltip)
#: src/kcfg/settings.kcfg:290
#, kde-format
msgid ""
"Show more certificate details, such as fingerprint, key length and "
"expiration dates"
msgstr ""
"Zobrazit další podrobnosti o certifikátu, jako jsou otisk, délka klíče a "
"data platnosti"

#. i18n: ectx: label, entry (WelcomeText), group (Welcome)
#: src/kcfg/settings.kcfg:296
#, kde-format
msgid "Custom Welcome text"
msgstr "Vlastní uvítací text"

#. i18n: ectx: whatsthis, entry (WelcomeText), group (Welcome)
#: src/kcfg/settings.kcfg:297
#, kde-format
msgid ""
"This text is shown on the Welcome page replacing most of the standard text."
msgstr ""
"Tento text se zobrazuje na úvodní stránce a nahrazuje většinu standardního "
"textu."

